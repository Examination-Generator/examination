# PostgreSQL Configuration
DB_NAME=examination_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Django Configuration
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Configuration
JWT_SECRET_KEY=exam-system-jwt-secret-change-in-production-2025
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SMS Provider Configuration (Africa's Talking)
# For development, set SMS_MOCK_MODE=true to avoid sending real SMS
SMS_PROVIDER=africastalking
SMS_USERNAME=sandbox
SMS_API_KEY=your_api_key_here
SMS_SENDER_ID=speedstar
SMS_MOCK_MODE=true

# Messaging Configuration
MAX_SMS_PER_MINUTE=10
MAX_SYSTEM_MESSAGES_PER_MINUTE=5
MESSAGE_MAX_LENGTH=5000
SMS_MAX_LENGTH=160
